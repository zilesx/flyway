FROM node:22-alpine AS build

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

COPY app ./app
COPY public ./public
COPY build ./build
COPY worker ./worker
COPY db ./db
COPY next.config.ts vite.config.ts tsconfig.json postcss.config.mjs ./
COPY drizzle.config.ts eslint.config.mjs ./
COPY .openai ./.openai

ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV WRANGLER_LOG_PATH=.wrangler/wrangler.log

RUN npm exec vinext build

FROM node:22-alpine

WORKDIR /app
COPY --from=build /app ./

ENV NODE_ENV=production
ENV WRANGLER_LOG_PATH=.wrangler/wrangler.log

EXPOSE 3000

CMD ["npm", "exec", "vinext", "start", "--", "--host", "0.0.0.0", "--port", "3000"]
